# Anthropic API key for the analyzer and script generator.
ANTHROPIC_API_KEY=

# Upstash Redis (lead storage). Added automatically (as KV_*) when you
# connect an Upstash Redis database from the Vercel Marketplace to this
# project. UPSTASH_* names are also accepted.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Stripe secret key — used only to verify the checkout session is paid
# before generating the counter-offer script.
STRIPE_SECRET_KEY=

# Shared secret for exporting leads as CSV:
#   GET /api/leads?token=<this value>
# Pick any long random string.
LEADS_EXPORT_TOKEN=
